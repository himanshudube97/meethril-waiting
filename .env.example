# Resend — used to add waitlist signups to an Audience.
# Reuse Hearth's RESEND_API_KEY or create a fresh one labeled "Meethril".
RESEND_API_KEY=re_xxxxxxxxxxxx

# Resend Segment ID for the Meethril waitlist contact list.
# Created once in resend.com → Segments → "Meethril Waitlist".
# (Resend renamed Audiences → Segments — same UUID concept.)
RESEND_SEGMENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# From address for the welcome email.
# Domain must be verified in resend.com → Domains first.
RESEND_FROM_EMAIL=meethril <hello@meethril.com>

# Public site origin — used to build absolute unsubscribe URLs in the welcome email.
# In production, set to your custom domain (e.g. https://meethril.com).
# In Vercel previews / local dev, the request host is used as a fallback.
SITE_URL=https://meethril.com

# Secret used to sign unsubscribe tokens (HMAC). Anything random and >= 32 chars.
# Generate with: openssl rand -hex 32
UNSUBSCRIBE_SECRET=replace-with-32-char-random-hex

# Used for og metadata only.
NEXT_PUBLIC_LAUNCH_DATE=2026-05-29
